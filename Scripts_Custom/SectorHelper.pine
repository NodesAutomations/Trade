//@version=5
library("SectorHelper", overlay=true)

export type ScreenerSector
    int S1
    int S2
    int S3
    int S4

      
export method GetMapDataScreenerSector(string data) =>
    var screenerMap = map.new<string, ScreenerSector>()
    if data !=""
        lines = str.split(data, "\n")
        for i = 0 to array.size(lines) - 1
            line = array.get(lines, i)
            parts= str.split(line,",")
            if parts.size()==5 
                string ticker = parts.get(0)
                int s1 = int(str.tonumber(parts.get(1)))
                int s2 = int(str.tonumber(parts.get(2)))
                int s3 = int(str.tonumber(parts.get(3)))
                int s4 = int(str.tonumber(parts.get(4)))
                screenerMap.put(ticker,ScreenerSector.new(s1,s2,s3,s4))
    screenerMap
 
export method GetS1(int id) =>
    var s1Map = map.new<int, string>() 
    s1Map.put(0,"-")
    s1Map.put(1,"Commodities")
    s1Map.put(2,"Financial Services")
    s1Map.put(3,"Information Technology")
    s1Map.put(4,"Diversified")
    s1Map.put(5,"Industrials")
    s1Map.put(6,"Services")
    s1Map.put(7,"Energy")
    s1Map.put(8,"Healthcare")
    s1Map.put(9,"Consumer Discretionary")
    s1Map.put(10,"Fast Moving Consumer Goods")
    s1Map.put(11,"Utilities")
    s1Map.put(12,"Telecommunication")
    s1Map.get(id)

